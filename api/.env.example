PORT=4100
NODE_ENV=development

# Storage provider:
# - file: local JSON file at DB_PATH
# - postgres: durable Postgres state at DATABASE_URL
STORAGE_PROVIDER=file
DB_PATH=./db.local.json
DATABASE_URL=
PG_POOL_MAX=5
PG_CONNECT_TIMEOUT_MS=8000
PG_IDLE_TIMEOUT_MS=30000

# Browser origins allowed by CORS (comma-separated, no trailing slash).
# Native mobile requests without an Origin header are still allowed.
# First live dashboard example:
# CORS_ALLOWED_ORIGINS=https://app.peritio.ai
# If this API already serves another web app, append the new origin instead of replacing the current list.
CORS_ALLOWED_ORIGINS=http://localhost:3000

ADMIN_BOOTSTRAP_PASSWORD=admin
ADMIN_TOKEN_SECRET=replace_me_for_production
ADMIN_TOKEN_TTL_MINUTES=720
WEB_AUTH_TOKEN_SECRET=replace_me_for_shared_web_auth
# OTP delivery:
# - AUTH_CODE_DELIVERY_PROVIDER is the default for all auth-code flows unless overridden below.
# - WEB_AUTH_CODE_DELIVERY_PROVIDER applies to dashboard sign-in and dashboard email verification.
# - MOBILE_EMAIL_VERIFICATION_DELIVERY_PROVIDER applies to mobile onboarding/settings verification.
# - log_only: local/dev friendly, codes are written to API logs
# - resend: sends real OTP emails via Resend
AUTH_CODE_DELIVERY_PROVIDER=log_only
WEB_AUTH_CODE_DELIVERY_PROVIDER=
MOBILE_EMAIL_VERIFICATION_DELIVERY_PROVIDER=
RESEND_API_KEY=
AUTH_CODE_FROM_EMAIL=
AUTH_CODE_FROM_NAME=Peritio
AUTH_CODE_REPLY_TO=
MOBILE_TOKEN_SECRET=replace_me_for_mobile_tokens
# Local-only shared web-auth test identities.
PERITIO_LOCAL_SUPER_USER_EMAIL=super-user@peritio.local
# Compatibility fallback for older local setups that still use the legacy env name.
PERITIO_LOCAL_PLATFORM_ADMIN_EMAIL=
PERITIO_LOCAL_CUSTOMER_EMAIL=customer-admin@primary.local
PERITIO_LOCAL_SECOND_CUSTOMER_EMAIL=customer-admin@secondary.local
# In production this defaults to true when unset.
MOBILE_REVERIFY_ON_ONBOARD=false

# Optional: enable remote AI routes (opening/turn/scoring/transcription) via OpenAI.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_API_FAMILY=chat_completions
# Optional for Responses API calls only: none, minimal, low, medium, high, or xhigh.
OPENAI_CHAT_REASONING_EFFORT=
# Optional: simulation routes only (opening/turn/score). Falls back to OPENAI_CHAT_MODEL.
OPENAI_SIMULATION_MODEL=
# Optional: chat_completions or responses. Set this explicitly when changing simulation models.
OPENAI_SIMULATION_API_FAMILY=
# Optional Responses API reasoning effort per simulation route.
OPENAI_SIMULATION_OPENING_REASONING_EFFORT=
OPENAI_SIMULATION_TURN_REASONING_EFFORT=
OPENAI_SIMULATION_SCORE_REASONING_EFFORT=
# Optional route-specific simulation output caps. Defaults: opening=160, turn=220, score=1200.
OPENAI_SIMULATION_OPENING_MAX_OUTPUT_TOKENS=
OPENAI_SIMULATION_TURN_MAX_OUTPUT_TOKENS=
OPENAI_SIMULATION_SCORE_MAX_OUTPUT_TOKENS=
# Legacy aggregate fallback for all three simulation caps. Prefer the route-specific variables above.
OPENAI_SIMULATION_MAX_OUTPUT_TOKENS=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
ENABLE_REMOTE_TTS=false
# Optional AI budget caps (non-negative integers). Defaults are applied in production when OPENAI_API_KEY is set.
OPENAI_MAX_DAILY_CALLS_PER_USER=
OPENAI_MAX_DAILY_CALLS_GLOBAL=
OPENAI_MAX_DAILY_TOKENS_PER_USER=
OPENAI_MAX_DAILY_TOKENS_GLOBAL=

# Optional: enable modular prompt orchestration/training-pack behavior.
# Default is false to preserve current behavior.
USE_MODULAR_PROMPT_ARCHITECTURE=false

# Optional: enable internal prompt-debug endpoint.
# Default is false. When false, /internal/* debug endpoints return 404.
ENABLE_INTERNAL_DEBUG_ENDPOINTS=false

# Required in production: secret for encrypting support transcripts at rest.
SUPPORT_TRANSCRIPT_SECRET=replace_me_for_production
