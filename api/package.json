{
  "name": "@voicepractice/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "seed:dashboard-local": "node ./scripts/seed-dashboard-local.mjs",
    "reset:simulation-baseline": "tsx ./scripts/reset-simulation-baseline.ts",
    "reset:pretester-history": "tsx ./scripts/reset-pretester-history.ts --local-file",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@voicepractice/shared": "file:../shared",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.2",
    "typescript": "~6.0.3"
  }
}
