{
  "name": "@voicepractice/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "seed:dashboard-local": "node ./scripts/seed-dashboard-local.mjs",
    "db:sanitize-bootstrap": "tsx ./scripts/sanitize-bootstrap.ts",
    "reset:simulation-baseline": "tsx ./scripts/reset-simulation-baseline.ts",
    "reset:pretester-history": "tsx ./scripts/reset-pretester-history.ts --local-file",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@voicepractice/shared": "file:../shared",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "multer": "^2.0.2",
    "pg": "^8.18.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.16.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2"
  }
}
